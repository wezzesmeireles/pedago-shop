# ─── JWT (gere strings aleatórias longas) ────────────────────
JWT_ACCESS_SECRET=troque_por_string_aleatoria_longa_32chars
JWT_REFRESH_SECRET=troque_por_outra_string_aleatoria_longa
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── URLs (seus dominios no Coolify) ────────────────────────
