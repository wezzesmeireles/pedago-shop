# ═══════════════════════════════════════════════════════
# PEDAGO SHOP — Variáveis de ambiente Docker
# Copie para .env e preencha os valores
# ═══════════════════════════════════════════════════════

# ── Domínio ────────────────────────────────────────────
DOMAIN=localhost
FRONTEND_URL=http://localhost:5173
API_URL=http://localhost:3000

# ── PostgreSQL ─────────────────────────────────────────
POSTGRES_DB=pedago
POSTGRES_USER=pedago
POSTGRES_PASSWORD=changeme_postgres
POSTGRES_PORT=5432

DATABASE_URL=postgresql://pedago:changeme_postgres@postgres:5432/pedago

# ── Redis ──────────────────────────────────────────────
REDIS_PASSWORD=changeme_redis
REDIS_PORT=6379
REDIS_URL=redis://:changeme_redis@redis:6379

# ── MinIO ──────────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=changeme_minio
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ENDPOINT=minio

S3_ENDPOINT=minio
S3_PORT=9000
S3_USE_SSL=false
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=changeme_minio
S3_BUCKET_COVERS=product-covers
S3_BUCKET_PREVIEWS=product-previews
S3_BUCKET_FILES=product-files
S3_PUBLIC_URL=http://localhost:9000

# ── JWT ────────────────────────────────────────────────
JWT_SECRET=changeme_jwt_secret_must_be_long_and_random
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ── Google OAuth ───────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# ── NestJS API ─────────────────────────────────────────
API_PORT=3000
NODE_ENV=development

# ── Mercado Pago ───────────────────────────────────────
MERCADO_PAGO_ACCESS_TOKEN=
MERCADO_PAGO_WEBHOOK_SECRET=

# ── Telegram ───────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
