// ═══════════════════════════════════════════════════════
// Pedago Shop — Prisma Schema
// Espelha o schema Supabase com campos extras para auth própria
// ═══════════════════════════════════════════════════════

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────────────────────────

enum Role {
  CUSTOMER
  ADMIN
}

enum OrderStatus {
  PENDING
  AWAITING_PAYMENT
  PAID
  CANCELLED
  REFUNDED
  EXPIRED
}

enum PaymentMethod {
  PIX
  CREDIT_CARD
  DEBIT_CARD
}

enum DeliveryType {
  pdf
  link
}

enum WebhookStatus {
  processing
  processed
  skipped
  failed
}

// ─────────────────────────────────────────────────────────────────
// User — substitui auth.users + profiles do Supabase
// ─────────────────────────────────────────────────────────────────
model User {
  id           String    @id @default(uuid()) @db.Uuid
  email        String    @unique
  // Hash bcrypt. Compatível com hashes legados do Supabase GoTrue.
  // null para usuários OAuth (Google) sem senha definida.
  passwordHash String?   @map("password_hash")
  name         String    @default("")
  phone        String?
  avatarUrl    String?   @map("avatar_url")
  role         Role      @default(CUSTOMER)
  isActive     Boolean   @default(true) @map("is_active")
  // Provider OAuth
  googleId     String?   @unique @map("google_id")
  deletedAt    DateTime? @map("deleted_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  orders       Order[]

  @@map("users")
}

// ─────────────────────────────────────────────────────────────────
// Category
// ─────────────────────────────────────────────────────────────────
model Category {
  id          String    @id @default(uuid()) @db.Uuid
  name        String
  slug        String    @unique
  description String?
  imageUrl    String?   @map("image_url")
  sortOrder   Int       @default(0) @map("sort_order")
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  products    Product[]

  @@map("categories")
}

// ─────────────────────────────────────────────────────────────────
// Product
// ─────────────────────────────────────────────────────────────────
model Product {
  id             String       @id @default(uuid()) @db.Uuid
  name           String
  slug           String       @unique
  description    String       @default("")
  richContent    String?      @map("rich_content")
  price          Decimal      @db.Decimal(10, 2)
  comparePrice   Decimal?     @map("compare_price") @db.Decimal(10, 2)
  coverImageUrl  String       @default("") @map("cover_image_url")
  previewImages  String[]     @default([]) @map("preview_images")
  categoryId     String?      @map("category_id") @db.Uuid
  // Arquivo PDF no S3
  fileKey        String       @default("") @map("file_key")
  fileSize       Int          @default(0) @map("file_size")
  pageCount      Int?         @map("page_count")
  // Entrega
  deliveryType   DeliveryType @default(pdf) @map("delivery_type")
  deliveryLink   String?      @map("delivery_link")
  // Mídia
  youtubeUrl     String?      @map("youtube_url")
  instagramUrl   String?      @map("instagram_url")
  // Metadados
  tags           String[]     @default([])
  isActive       Boolean      @default(true) @map("is_active")
  isFeatured     Boolean      @default(false) @map("is_featured")
  sortOrder      Int          @default(0) @map("sort_order")
  salesCount     Int          @default(0) @map("sales_count")
  deletedAt      DateTime?    @map("deleted_at")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  category       Category?    @relation(fields: [categoryId], references: [id])
  orderItems     OrderItem[]

  @@map("products")
}

// ─────────────────────────────────────────────────────────────────
// Order
// ─────────────────────────────────────────────────────────────────
model Order {
  id              String        @id @default(uuid()) @db.Uuid
  orderNumber     String        @unique @map("order_number")
  userId          String        @map("user_id") @db.Uuid
  status          OrderStatus   @default(AWAITING_PAYMENT)
  totalAmount     Decimal       @map("total_amount") @db.Decimal(10, 2)
  paymentMethod   PaymentMethod? @map("payment_method")
  // Mercado Pago
  mpPreferenceId  String?       @map("mp_preference_id")
  mpPaymentId     String?       @unique @map("mp_payment_id")
  mpStatus        String?       @map("mp_status")
  // Timestamps de negócio
  paidAt          DateTime?     @map("paid_at")
  expiresAt       DateTime?     @map("expires_at")
  // Snapshot do cliente
  customerEmail   String        @map("customer_email")
  customerName    String        @map("customer_name")
  metadata        Json?
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  user            User          @relation(fields: [userId], references: [id])
  orderItems      OrderItem[]
  downloadTokens  DownloadToken[]

  @@map("orders")
}

// ─────────────────────────────────────────────────────────────────
// OrderItem
// ─────────────────────────────────────────────────────────────────
model OrderItem {
  id          String   @id @default(uuid()) @db.Uuid
  orderId     String   @map("order_id") @db.Uuid
  productId   String   @map("product_id") @db.Uuid
  productName String   @map("product_name")
  unitPrice   Decimal  @map("unit_price") @db.Decimal(10, 2)
  quantity    Int      @default(1)
  createdAt   DateTime @default(now()) @map("created_at")

  order          Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product        Product        @relation(fields: [productId], references: [id])
  downloadTokens DownloadToken[]

  @@map("order_items")
}

// ─────────────────────────────────────────────────────────────────
// DownloadToken
// ─────────────────────────────────────────────────────────────────
model DownloadToken {
  id             String    @id @default(uuid()) @db.Uuid
  token          String    @unique @default(uuid())
  orderId        String    @map("order_id") @db.Uuid
  orderItemId    String    @map("order_item_id") @db.Uuid
  downloadCount  Int       @default(0) @map("download_count")
  maxDownloads   Int       @default(99999) @map("max_downloads")
  expiresAt      DateTime  @map("expires_at")
  lastDownloadAt DateTime? @map("last_download_at")
  lastDownloadIp String?   @map("last_download_ip")
  revokedAt      DateTime? @map("revoked_at")
  // URL externa (copiada de products.deliveryLink)
  deliveryLink   String?   @map("delivery_link")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  order     Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderItem OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)

  @@map("download_tokens")
}

// ─────────────────────────────────────────────────────────────────
// WebhookEvent — idempotência para webhooks do Mercado Pago
// ─────────────────────────────────────────────────────────────────
model WebhookEvent {
  id           String        @id @default(uuid()) @db.Uuid
  source       String
  eventId      String        @map("event_id")
  eventType    String        @map("event_type")
  payload      Json
  status       WebhookStatus @default(processing)
  errorMessage String?       @map("error_message")
  processedAt  DateTime      @default(now()) @map("processed_at")

  @@unique([source, eventId])
  @@map("webhook_events")
}

// ─────────────────────────────────────────────────────────────────
// SiteConfig — configuração global da loja
// ─────────────────────────────────────────────────────────────────
model SiteConfig {
  id               String   @id @default(uuid()) @db.Uuid
  key              String   @unique
  value            Json
  updatedAt        DateTime @updatedAt @map("updated_at")
  updatedByAdminId String?  @map("updated_by_admin_id") @db.Uuid

  @@map("site_config")
}
